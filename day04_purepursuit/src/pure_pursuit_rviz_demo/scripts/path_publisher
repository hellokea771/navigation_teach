#!/usr/bin/env python3
"""Publishes reference path: straight segment + circle."""

import math
import rclpy
from rclpy.node import Node
from nav_msgs.msg import Path
from geometry_msgs.msg import PoseStamped
from std_msgs.msg import Header
from common import REFERENCE_PATH_TOPIC, ODOM_FRAME


class PathPublisher(Node):
    def __init__(self):
        super().__init__('path_publisher')
        self.publisher_ = self.create_publisher(Path, REFERENCE_PATH_TOPIC, 10)

        self.path = Path()
        self.path.header = Header(frame_id=ODOM_FRAME)

        # 直线段 3m
        for i in range(31):
            self._add_pose(i * 0.1, 0.0)

        # 圆圈段 r=1.5m，从直线终点(3,0)开始
        cx, cy, r = 3.0, 1.5, 1.5
        for i in range(61):
            theta = 2 * math.pi * i / 60 - math.pi / 2
            self._add_pose(cx + r * math.cos(theta), cy + r * math.sin(theta))

        self.get_logger().info(f'Path ready: {len(self.path.poses)} poses')
        self.publish_path()
        self.timer = self.create_timer(1.0, self.publish_path)  # 1Hz

    def _add_pose(self, x, y):
        p = PoseStamped()
        p.header = Header(frame_id=ODOM_FRAME)
        p.pose.position.x = x
        p.pose.position.y = y
        p.pose.orientation.w = 1.0
        self.path.poses.append(p)

    def publish_path(self):
        stamp = self.get_clock().now().to_msg()
        self.path.header.stamp = stamp
        for pose in self.path.poses:
            pose.header.stamp = stamp
        self.publisher_.publish(self.path)


def main(args=None):
    rclpy.init(args=args)
    node = PathPublisher()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()
