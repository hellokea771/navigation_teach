#!/usr/bin/env python3
"""
virtual_robot.py

Simulates a differential-drive robot chassis.
Subscribes to /cmd_vel, integrates motion using a simple model,
and publishes /odom, TF (odom -> base_link), and /actual_path.
"""

import math
import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist, TransformStamped, PoseStamped
from nav_msgs.msg import Odometry, Path
from std_msgs.msg import Header
import tf2_ros

from common import (
    CMD_VEL_TOPIC, ODOM_TOPIC, ACTUAL_PATH_TOPIC,
    ODOM_FRAME, BASE_LINK_FRAME,
    quaternion_from_yaw,
)


class VirtualRobot(Node):

    def __init__(self):
        super().__init__('virtual_robot')

        self.x = 0.0
        self.y = 0.0
        self.yaw = 0.0

        self.v = 0.0
        self.omega = 0.0

        self.last_time = self.get_clock().now()

        self.odom_pub = self.create_publisher(Odometry, ODOM_TOPIC, 10)
        self.path_pub = self.create_publisher(Path, ACTUAL_PATH_TOPIC, 10)
        self.tf_broadcaster = tf2_ros.TransformBroadcaster(self)

        self.create_subscription(Twist, CMD_VEL_TOPIC, self.cmd_vel_callback, 10)

        self.create_timer(0.02, self.update)

        self.actual_path = Path()
        self.actual_path.header = Header(frame_id=ODOM_FRAME)
        self.path_sample_counter = 0
        self.path_sample_interval = 5

        self.get_logger().info('Virtual robot started at (0, 0, 0)')

    def cmd_vel_callback(self, msg: Twist):
        self.v = msg.linear.x
        self.omega = msg.angular.z

    def update(self):
        now = self.get_clock().now()
        dt = (now - self.last_time).nanoseconds / 1e9
        self.last_time = now

        if dt > 0.1:
            dt = 0.02
        if dt <= 0.0:
            return

        self.x += self.v * math.cos(self.yaw) * dt
        self.y += self.v * math.sin(self.yaw) * dt
        self.yaw += self.omega * dt
        self.yaw = math.atan2(math.sin(self.yaw), math.cos(self.yaw))

        q = quaternion_from_yaw(self.yaw)

        # --- Odom ---
        odom = Odometry()
        odom.header = Header(stamp=now.to_msg(), frame_id=ODOM_FRAME)
        odom.child_frame_id = BASE_LINK_FRAME
        odom.pose.pose.position.x = self.x
        odom.pose.pose.position.y = self.y
        odom.pose.pose.orientation = q
        odom.twist.twist.linear.x = self.v
        odom.twist.twist.angular.z = self.omega
        self.odom_pub.publish(odom)

        # --- TF ---
        t = TransformStamped()
        t.header = Header(stamp=now.to_msg(), frame_id=ODOM_FRAME)
        t.child_frame_id = BASE_LINK_FRAME
        t.transform.translation.x = self.x
        t.transform.translation.y = self.y
        t.transform.rotation = q
        self.tf_broadcaster.sendTransform(t)

        # --- Path ---
        self.path_sample_counter += 1
        if self.path_sample_counter % self.path_sample_interval == 0:
            pose = PoseStamped()
            pose.header = Header(stamp=now.to_msg(), frame_id=ODOM_FRAME)
            pose.pose.position.x = self.x
            pose.pose.position.y = self.y
            pose.pose.orientation = q
            self.actual_path.poses.append(pose)
            if len(self.actual_path.poses) > 5000:
                self.actual_path.poses = self.actual_path.poses[-1000:]
            self.actual_path.header.stamp = now.to_msg()
            self.path_pub.publish(self.actual_path)


def main(args=None):
    rclpy.init(args=args)
    node = VirtualRobot()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()
