#!/usr/bin/env python3
"""
pure_pursuit_controller.py

Implements a Pure Pursuit controller.
Subscribes to /reference_path and /odom.
Publishes /cmd_vel and /lookahead_point (visualisation Marker).
"""

import math
import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist, Point
from nav_msgs.msg import Path, Odometry
from visualization_msgs.msg import Marker
from std_msgs.msg import Header, ColorRGBA

from common import (
    REFERENCE_PATH_TOPIC, CMD_VEL_TOPIC, ODOM_TOPIC,
    LOOKAHEAD_POINT_TOPIC, ODOM_FRAME,
    DEFAULT_LOOKAHEAD_DISTANCE, DEFAULT_TARGET_SPEED,
    heading_from_quaternion, LOOKAHEAD_COLOR,
)


class PurePursuitController(Node):

    def __init__(self):
        super().__init__('pure_pursuit_controller')

        self.declare_parameter('lookahead_distance', DEFAULT_LOOKAHEAD_DISTANCE)
        self.declare_parameter('target_speed', DEFAULT_TARGET_SPEED)
        self.declare_parameter('control_rate', 20.0)

        self.lookahead_distance = self.get_parameter('lookahead_distance').value
        self.target_speed = self.get_parameter('target_speed').value
        rate = self.get_parameter('control_rate').value

        self.get_logger().info(
            f'Pure Pursuit started: lookahead={self.lookahead_distance}, '
            f'speed={self.target_speed}'
        )

        self.reference_path = None

        self.robot_x = 0.0
        self.robot_y = 0.0
        self.robot_yaw = 0.0

        self.cmd_pub = self.create_publisher(Twist, CMD_VEL_TOPIC, 10)
        self.marker_pub = self.create_publisher(Marker, LOOKAHEAD_POINT_TOPIC, 10)

        self.path_sub = self.create_subscription(
            Path, REFERENCE_PATH_TOPIC, self.path_callback, 10)
        self.odom_sub = self.create_subscription(
            Odometry, ODOM_TOPIC, self.odom_callback, 10)

        self.create_timer(1.0 / rate, self.control_loop)

        self.control_counter = 0

    def path_callback(self, msg: Path):
        self.reference_path = msg
        self.get_logger().info(f'Received reference path with {len(msg.poses)} poses')

    def odom_callback(self, msg: Odometry):
        self.robot_x = msg.pose.pose.position.x
        self.robot_y = msg.pose.pose.position.y
        self.robot_yaw = heading_from_quaternion(msg.pose.pose.orientation)

    def _find_lookahead_point(self):
        if self.reference_path is None or len(self.reference_path.poses) < 2:
            return None

        poses = self.reference_path.poses

        closest_idx = 0
        closest_dist = float('inf')
        for i, p in enumerate(poses):
            dx = p.pose.position.x - self.robot_x
            dy = p.pose.position.y - self.robot_y
            d = dx * dx + dy * dy
            if d < closest_dist:
                closest_dist = d
                closest_idx = i

        ld2 = self.lookahead_distance * self.lookahead_distance
        lookahead_idx = closest_idx
        found = False

        for i in range(closest_idx, len(poses)):
            dx = poses[i].pose.position.x - self.robot_x
            dy = poses[i].pose.position.y - self.robot_y
            d2 = dx * dx + dy * dy
            if d2 >= ld2:
                lookahead_idx = i
                found = True
                break

        if not found:
            lookahead_idx = len(poses) - 1

        target = poses[lookahead_idx].pose.position
        return (target.x, target.y, lookahead_idx)

    def control_loop(self):
        if self.reference_path is None:
            return

        result = self._find_lookahead_point()
        if result is None:
            return

        lx, ly, _ = result

        dx = lx - self.robot_x
        dy = ly - self.robot_y
        target_distance = math.sqrt(dx * dx + dy * dy)

        if target_distance < 0.001:
            return

        target_angle = math.atan2(dy, dx)
        alpha = target_angle - self.robot_yaw
        alpha = math.atan2(math.sin(alpha), math.cos(alpha))

        curvature = 2.0 * math.sin(alpha) / target_distance

        v = self.target_speed
        omega = v * curvature
        omega = max(-2.0, min(2.0, omega))

        cmd = Twist()
        cmd.linear.x = v
        cmd.angular.z = omega
        self.cmd_pub.publish(cmd)

        self._publish_lookahead_marker(lx, ly)

        self.control_counter += 1
        if self.control_counter % 50 == 0:
            self.get_logger().info(
                f'pose=({self.robot_x:.2f},{self.robot_y:.2f},{self.robot_yaw:.2f}) '
                f'lookahead=({lx:.2f},{ly:.2f}) '
                f'alpha={alpha:.2f} curvature={curvature:.2f} '
                f'v={v:.2f} omega={omega:.2f}'
            )

    def _publish_lookahead_marker(self, x, y):
        marker = Marker()
        marker.header = Header(stamp=self.get_clock().now().to_msg(), frame_id=ODOM_FRAME)
        marker.ns = 'lookahead'
        marker.id = 0
        marker.type = Marker.SPHERE
        marker.action = Marker.ADD
        marker.pose.position = Point(x=x, y=y, z=0.1)
        marker.pose.orientation.w = 1.0
        marker.scale.x = 0.25
        marker.scale.y = 0.25
        marker.scale.z = 0.25
        marker.color = ColorRGBA(r=LOOKAHEAD_COLOR[0], g=LOOKAHEAD_COLOR[1],
                                 b=LOOKAHEAD_COLOR[2], a=LOOKAHEAD_COLOR[3])
        marker.lifetime.sec = 1
        self.marker_pub.publish(marker)


def main(args=None):
    rclpy.init(args=args)
    node = PurePursuitController()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()
