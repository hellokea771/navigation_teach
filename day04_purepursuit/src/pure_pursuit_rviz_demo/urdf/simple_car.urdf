<?xml version="1.0"?>
<robot name="simple_car">

  <material name="body">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>
  <material name="front">
    <color rgba="1.0 0.2 0.1 1.0"/>
  </material>
  <material name="wheel">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry><box size="0.5 0.3 0.1"/></geometry>
      <material name="body"/>
    </visual>
  </link>

  <link name="body_link">
    <visual>
      <geometry><box size="0.35 0.24 0.12"/></geometry>
      <material name="body"/>
    </visual>
  </link>
  <joint name="base_to_body" type="fixed">
    <parent link="base_link"/>
    <child link="body_link"/>
    <origin xyz="0.0 0.0 0.12"/>
  </joint>

  <link name="front_link">
    <visual>
      <geometry><box size="0.08 0.22 0.06"/></geometry>
      <material name="front"/>
    </visual>
  </link>
  <joint name="base_to_front" type="fixed">
    <parent link="base_link"/>
    <child link="front_link"/>
    <origin xyz="0.29 0.0 0.02"/>
  </joint>

  <link name="left_front_wheel_link">
    <visual>
      <geometry><cylinder radius="0.06" length="0.04"/></geometry>
      <material name="wheel"/>
    </visual>
  </link>
  <joint name="base_to_left_front" type="fixed">
    <parent link="base_link"/>
    <child link="left_front_wheel_link"/>
    <origin xyz="0.15 0.17 -0.05" rpy="0 1.5708 0"/>
  </joint>

  <link name="right_front_wheel_link">
    <visual>
      <geometry><cylinder radius="0.06" length="0.04"/></geometry>
      <material name="wheel"/>
    </visual>
  </link>
  <joint name="base_to_right_front" type="fixed">
    <parent link="base_link"/>
    <child link="right_front_wheel_link"/>
    <origin xyz="0.15 -0.17 -0.05" rpy="0 1.5708 0"/>
  </joint>

  <link name="left_rear_wheel_link">
    <visual>
      <geometry><cylinder radius="0.06" length="0.04"/></geometry>
      <material name="wheel"/>
    </visual>
  </link>
  <joint name="base_to_left_rear" type="fixed">
    <parent link="base_link"/>
    <child link="left_rear_wheel_link"/>
    <origin xyz="-0.15 0.17 -0.05" rpy="0 1.5708 0"/>
  </joint>

  <link name="right_rear_wheel_link">
    <visual>
      <geometry><cylinder radius="0.06" length="0.04"/></geometry>
      <material name="wheel"/>
    </visual>
  </link>
  <joint name="base_to_right_rear" type="fixed">
    <parent link="base_link"/>
    <child link="right_rear_wheel_link"/>
    <origin xyz="-0.15 -0.17 -0.05" rpy="0 1.5708 0"/>
  </joint>

</robot>
